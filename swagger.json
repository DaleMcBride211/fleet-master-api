                    "dimensions": {
                      "type": "string",
                      "example": "183x253x77 mm"
                    },
                    "batteryCapacity": {
                      "type": "string",
                      "example": "3500 mAh"
                    },
                    "powerSource": {
                      "type": "string",
                      "example": "LiPo"
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          }
        }
